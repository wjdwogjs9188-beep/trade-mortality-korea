# API keys for data collection
# Copy this file to .env and fill in your keys.
# .env is gitignored — your keys are NOT shared.

# Bank of Korea ECOS API
# https://ecos.bok.or.kr/
ECOS_API_KEY=YOUR_ECOS_KEY_HERE

# UN Comtrade API
# https://comtradeplus.un.org/
# Get key at https://uncomtrade.org/docs/getting-started/
COMTRADE_API_KEY=YOUR_COMTRADE_KEY_HERE

# 공공데이터포털 (data.go.kr) — HIRA, KOSIS 등
DATA_GO_KR_API_KEY=YOUR_DATA_GO_KR_KEY_HERE
